# Copy to .env and fill in. All values are optional — with none set, the app runs
# fully on the deterministic rule-based NLU (zero cost, no key).

# --- NLU / LLM ---------------------------------------------------------------
# Provider for the query-understanding layer. "gemini" | "none".
LLM_PROVIDER=gemini
# Free Google AI Studio key: https://aistudio.google.com/apikey
# Leave empty to force the rule-based fallback.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Backend -----------------------------------------------------------------
# Path to the players dataset (defaults to the committed CSV inside the image).
# CSV_PATH=app/data/players.csv
# Comma-separated allowed CORS origins for the frontend.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Frontend (only needed when NOT using the docker/nginx proxy) ------------
# In docker-compose, nginx proxies /api -> backend, so this stays unset.
# For a standalone frontend build pointing at a remote API, set e.g.:
# VITE_API_URL=http://localhost:8000
